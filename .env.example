# Toolforge / bastion connection (read by the backend at startup)
# Path to your Toolforge SSH private key on this machine.
TOOLFORGE_SSH_KEY=~/.ssh/id_rsa
# Toolforge bastion host (default if unset: login.toolforge.org).
TOOLFORGE_BASTION_HOST=login.toolforge.org

# Deployr catalogue database (MariaDB / MySQL wire-compatible)
DEPLOYR_DB_HOST=127.0.0.1
DEPLOYR_DB_PORT=3306
DEPLOYR_DB_USER=root
DEPLOYR_DB_PASS=
DEPLOYR_DB_NAME=deployr

# GitHub token for raising continuous-deployment PRs (optional)
GITHUB_TOKEN=
